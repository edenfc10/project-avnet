# ============================================================================
# Dockerfile - Frontend (React + Vite)
# ============================================================================
# בונה את שרת ה-Frontend על בסיס Node 20.
# חושף פורט 5173 (ברירת מחדל של Vite).
# ההתקנה של node_modules מתבצעת ב-docker-compose (command).
# ============================================================================

FROM node:20-alpine

WORKDIR /app

EXPOSE 5173

# הפעלת שרת פיתוח
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

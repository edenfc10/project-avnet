# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=meet_control

# Backend JWT
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256

# Initial super admin
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=CHANGE_ME

# CMS Integration (Backend)
# ה-backend מטפל ב-MOCK CMS דרך /cms_mock/*
# או מתחבר לשרת CMS אמיתי לפי הגדרות
CMS_PRIMARY_HOST=<CMS_LAB_SERVER_IP>
CMS_PRIMARY_PORT=8443
CMS_PRIMARY_USER=admin
CMS_PRIMARY_PASSWORD=<CMS_PASSWORD>

CMS_SECONDARY_HOST=<CMS_SECONDARY_IP>
CMS_SECONDARY_PORT=8443
CMS_SECONDARY_USER=admin
CMS_SECONDARY_PASSWORD=<CMS_PASSWORD>

# Frontend build-time settings
# השאר ריק כדי שה-Frontend ישתמש באותו origin ויעבור דרך Nginx reverse-proxy
VITE_API_URL=
# VITE_CMS_MODE=mock  - משתמש ב-backend mock endpoints (/cms_mock/*)
# VITE_CMS_MODE=remote - מתחבר לשרת CMS חיצוני ישירות
VITE_CMS_MODE=mock
VITE_CMS_URL=
